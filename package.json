{
	"name": "mizuki",
	"type": "module",
	"version": "9.0",
	"scripts": {
		"sync-content": "node scripts/sync-content.js",
		"sync-docs-mizuki": "node scripts/sync-docs-mizuki.mjs",
		"check-docs-mizuki": "node scripts/check-docs-mizuki.mjs",
		"check-docs-render": "node scripts/check-docs-render.mjs",
		"init-content": "node scripts/init-content-repo.js",
		"predev": "node scripts/sync-content.js || true",
		"prebuild": "node scripts/sync-content.js || true",
		"dev": "NODE_OPTIONS='--max-old-space-size=6144 --max-semi-space-size=2' astro dev",
		"dev:mem": "NODE_OPTIONS='--max-old-space-size=16384' astro dev",
		"start": "astro dev",
		"check": "astro check",
		"update-anime": "node scripts/update-anime.mjs",
		"update-bangumi": "node scripts/update-bangumi.mjs",
		"update-bilibili": "node scripts/update-bilibili.mjs",
		"update-feeds": "node scripts/update-feeds.mjs",
		"build": "node scripts/update-feeds.mjs && node scripts/update-anime.mjs && node scripts/run-with-mem.js astro build && node scripts/build-pagefind.mjs && node scripts/compress-fonts/index.js",
		"submit": "node scripts/indexnow-submit.js",
		"preview": "astro preview",
		"astro": "astro",
		"type-check": "tsc --noEmit",
		"new-post": "node scripts/new-post.js",
		"format": "prettier --write ./src",
		"lint": "eslint ./src --fix",
		"postinstall": "node scripts/patch-vite-timeout.js && node scripts/patch-data-store-load.js",
		"preinstall": "npx only-allow pnpm",
		"compress-fonts": "node scripts/compress-fonts/index.js"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/mdx": "^5.0.6",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.3",
		"@astrojs/svelte": "^8.1.2",
		"@expressive-code/core": "^0.42.0",
		"@expressive-code/plugin-collapsible-sections": "^0.41.7",
		"@expressive-code/plugin-line-numbers": "^0.41.7",
		"@fancyapps/ui": "^6.1.14",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource/roboto": "^5.2.10",
		"@iconify/svelte": "^5.2.1",
		"@swup/astro": "^1.8.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"astro": "^6.3.7",
		"astro-expressive-code": "^0.41.7",
		"astro-icon": "^1.1.5",
		"axios": "^1.16.0",
		"dayjs": "^1.11.20",
		"hastscript": "^9.0.1",
		"katex": "^0.16.45",
		"l2d-widget": "^0.0.2",
		"markdown-it": "^14.1.1",
		"marked": "^16.4.2",
		"node-html-parser": "^7.1.0",
		"oddmisc": "^1.2.2",
		"overlayscrollbars": "^2.15.1",
		"pagefind": "^1.5.2",
		"pako": "^2.1.0",
		"qrcode": "^1.5.4",
		"reading-time": "^1.5.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-components": "^0.3.0",
		"rehype-external-links": "^3.0.0",
		"rehype-katex": "^7.0.1",
		"rehype-slug": "^6.0.0",
		"remark-directive": "^3.0.1",
		"remark-directive-rehype": "^0.4.2",
		"remark-math": "^6.0.0",
		"remark-sectionize": "^2.1.0",
		"sanitize-html": "^2.17.3",
		"satori": "^0.26.0",
		"sharp": "^0.34.5",
		"stylus": "^0.64.0",
		"svelte": "^5.55.5",
		"tailwindcss": "^4.3.0",
		"typescript": "^5.9.3",
		"unist-util-visit": "^5.1.0"
	},
	"devDependencies": {
		"@astrojs/ts-plugin": "^1.10.9",
		"@eslint/js": "^10.0.1",
		"@iconify-json/fa7-brands": "^1.2.2",
		"@iconify-json/fa7-regular": "^1.2.3",
		"@iconify-json/fa7-solid": "^1.2.4",
		"@iconify-json/lucide": "^1.2.109",
		"@iconify-json/material-symbols": "^1.2.70",
		"@iconify-json/mdi": "^1.2.3",
		"@iconify-json/simple-icons": "^1.2.81",
		"@rollup/plugin-yaml": "^4.1.2",
		"@types/hast": "^3.0.4",
		"@types/markdown-it": "^14.1.2",
		"@types/mdast": "^4.0.4",
		"@types/qrcode": "^1.5.6",
		"@types/sanitize-html": "^2.16.1",
		"astro-eslint-parser": "^1.4.0",
		"eslint": "^10.3.0",
		"eslint-plugin-astro": "^1.7.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"eslint-plugin-svelte": "^3.17.1",
		"fast-xml-parser": "^5.8.0",
		"fontmin": "^1.1.1",
		"glob": "^13.0.6",
		"globals": "^17.6.0",
		"postcss-import": "^16.1.1",
		"postcss-nesting": "^14.0.0",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte-eslint-parser": "^1.6.1",
		"typescript-eslint": "^8.59.2"
	},
	"packageManager": "pnpm@10.33.0"
}
