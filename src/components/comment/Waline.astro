---
import { commentConfig, siteConfig } from "@/config";

interface Props {
  path: string;
}

const walineConfig = {
  ...commentConfig.waline,
  el: "#waline",
  path: Astro.props.path,
  lang: siteConfig.lang.replace("_", "-"),
  dark: 'html[data-theme="dark"]',
};
---

<div id="waline-container" class="waline-container">
  {/* Waline Container */}
  <div id="waline" class="not-prose"></div>

  {/* Loading indicator */}
  <div id="waline-loading" class="flex items-center justify-center py-8">
    <div class="animate-spin h-8 w-8 border-2 border-primary border-t-transparent rounded-full"></div>
  </div>

  {/* Fallback for disabled JS */}
  <noscript>
    <div class="rounded-lg bg-muted/50 p-4 text-center text-muted-foreground">
      请启用 JavaScript 以查看评论功能。
    </div>
  </noscript>

  <link rel="stylesheet" href="https://unpkg.com/@waline/client@v3/dist/waline.css" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://unpkg.com/@waline/client@v3/dist/waline.css" /></noscript>

  <script is:inline type="module" define:vars={{
    serverURL: walineConfig.serverURL ?? '',
    emoji: walineConfig.emoji ?? [],
    lang: walineConfig.lang ?? 'zh-CN',
    reaction: (walineConfig as any).reaction ?? false,
    pageview: walineConfig.visitorCount ?? false,
    login: walineConfig.login ?? 'enable',
    wordLimit: (walineConfig as any).wordLimit ?? [0, 0],
    imageUploader: (walineConfig as any).imageUploader ?? false,
    requiredMeta: (walineConfig as any).requiredMeta ?? [],
    copyright: (walineConfig as any).copyright ?? true
  }}>
    // Timeout fallback - hide loading after 15s max
    const LOADING_TIMEOUT = 15000;
    let timeoutId = null;

    function hideLoading() {
      const loading = document.getElementById('waline-loading');
      if (loading) {
        loading.style.display = 'none';
      }
      if (timeoutId) {
        clearTimeout(timeoutId);
        timeoutId = null;
      }
    }

    function showError(message) {
      const loading = document.getElementById('waline-loading');
      if (loading) {
        loading.innerHTML = '<div class="text-center text-muted-foreground">' + message + '</div>';
      }
    }

    // Set timeout to force hide loading
    timeoutId = setTimeout(function() {
      hideLoading();
    }, LOADING_TIMEOUT);

    // Dynamically import Waline client
    let walineInstance = null;
    let initFunc = null;

    // Wait for an external stylesheet to finish loading before rendering.
    // Resolves immediately if the stylesheet is already loaded or not found.
    // Falls back after timeout to avoid blocking initialization indefinitely.
    function waitForStylesheet(hrefSubstring, timeout) {
      timeout = timeout || 5000;
      return new Promise(function (resolve) {
        const links = document.querySelectorAll('link[rel="stylesheet"]');
        for (let i = 0; i < links.length; i++) {
          const link = links[i];
          if (link.href && link.href.indexOf(hrefSubstring) !== -1) {
            // Already loaded: sheet exists and is accessible
            try {
              if (link.sheet && link.sheet.cssRules) {
                resolve();
                return;
              }
            } catch (e) {
              // Cross-origin: check media was switched from "print"
              if (link.media !== 'print') {
                resolve();
                return;
              }
            }
            // Not loaded yet — wait for onload
            var resolved = false;
            link.addEventListener('load', function () {
              if (!resolved) { resolved = true; resolve(); }
            });
            // Timeout fallback
            setTimeout(function () {
              if (!resolved) { resolved = true; resolve(); }
            }, timeout);
            return;
          }
        }
        // Stylesheet link not found — proceed anyway
        resolve();
      });
    }

    function loadWaline() {
      const container = document.getElementById('waline');

      if (!container) {
        return;
      }

      if (!serverURL) {
        showError('评论系统未配置 serverURL');
        return;
      }

      try {
        // Clean up previous instance
        if (walineInstance) {
          const result = walineInstance.destroy();
          if (result && typeof result.catch === 'function') {
            result.catch(function() {});
          }
          walineInstance = null;
        }

        if (!initFunc) {
          showError('评论组件加载失败，请刷新重试');
          return;
        }

        walineInstance = initFunc({
          el: '#waline',
          serverURL: serverURL,
          emoji: emoji,
          lang: lang,
          reaction: reaction,
          pageview: pageview,
          login: login,
          wordLimit: wordLimit,
          imageUploader: imageUploader,
          requiredMeta: requiredMeta,
          copyright: copyright,
          dark: 'html[data-theme="dark"]',
          path: window.location.pathname.replace(/\/$/, ''),
          locale: {
            placeholder: '欢迎评论，支持 Markdown 语法。\n请遵守社区规范，友善发言。',
            sofa: '快来抢沙发吧~',
            submit: '发布评论',
            reply: '回复',
            cancelReply: '取消回复',
            comment: '评论',
            refresh: '刷新',
            more: '加载更多...',
            preview: '预览',
            emoji: '表情',
            uploadImage: '上传图片',
            seconds: '秒前',
            minutes: '分钟前',
            hours: '小时前',
            days: '天前',
            now: '刚刚',
            uploading: '上传中',
            login: '登录',
            logout: '退出',
            admin: '博主',
            sticky: '置顶',
            word: '字',
            wordHint: '评论字数应在 $0 到 $1 字之间！\n当前字数：$2',
            anonymous: '匿名',
            level0: '潜水',
            level1: '冒泡',
            level2: '吐槽',
            level3: '活跃',
            level4: '话痨',
            level5: '传说',
          },
        });

        // Hide loading indicator after successful load
        hideLoading();
      } catch (e) {
        showError('评论加载失败，请刷新重试');
      }
    }

    // Load Waline JS, then wait for CSS to be ready before initializing
    import('https://unpkg.com/@waline/client@v3/dist/waline.js')
      .then(function(module) {
        initFunc = module.init;
        if (!initFunc) {
          showError('评论组件加载异常');
          return;
        }
        waitForStylesheet('waline.css').then(loadWaline);
      })
      .catch(function(err) {
        showError('评论组件加载失败，请检查网络');
      });

    // Handle page load events
    document.addEventListener('astro:page-load', function() {
      waitForStylesheet('waline.css').then(loadWaline);
    });
    document.addEventListener('mizuki:page:loaded', function() {
      waitForStylesheet('waline.css').then(loadWaline);
    });

    // Suppress Waline AbortError (external service unavailability)
    const suppressWalineErrors = function(event) {
      if (event.message && event.message.includes('AbortError') &&
          (event.filename && event.filename.includes('waline') || event.message.includes('waline'))) {
        event.preventDefault();
        return true;
      }
      return false;
    };
    window.addEventListener('error', suppressWalineErrors);

    // Cleanup before page swap to prevent AbortError
    document.addEventListener('astro:before-swap', function() {
      if (walineInstance) {
        const result = walineInstance.destroy();
        if (result && typeof result.catch === 'function') {
          result.catch(function() {});
        }
        walineInstance = null;
      }
      window.removeEventListener('error', suppressWalineErrors);
    });

    // Also handle Swup events
    function setupSwupHooks() {
      if (window.swup && window.swup.hooks) {
        window.swup.hooks.on('content:replace', function() {
          setTimeout(function() {
            waitForStylesheet('waline.css').then(loadWaline);
          }, 200);
        });
      } else {
        document.addEventListener('swup:enable', function() {
          setupSwupHooks();
        }, { once: true });
      }
    }
    setupSwupHooks();
  </script>

  <style is:global>
    /* ===========================================
     * WALINE COMMENT SYSTEM STYLES
     * Comprehensive theming for light/dark modes
     * =========================================== */

    /* ===========================================
     * ROOT VARIABLES (Common)
     * =========================================== */
    :root {
      /* Theme Colors - inherit from project's theme system */
      --waline-theme-color: var(--primary) !important;
      --waline-active-color: var(--primary) !important;

      /* Typography */
      --waline-font-size: 0.9375rem !important;
      --waline-border-radius: var(--radius-lg, 0.5rem) !important;

      /* Avatar */
      --waline-avatar-size: 2.75rem !important;
      --waline-m-avatar-size: 2.25rem !important;

      /* Box Shadow */
      --waline-box-shadow: none !important;
    }

    /* ===========================================
     * LIGHT MODE THEME
     * =========================================== */
    html:not([data-theme="dark"]) {
      /* Primary Backgrounds */
      --waline-bg-color: var(--card) !important;
      --waline-bg-color-light: var(--muted) !important;
      --waline-bg-color-hover: var(--primary-soft) !important;

      /* Text Colors */
      --waline-color: var(--foreground) !important;
      --waline-font-color: var(--foreground) !important;

      /* Border & Disabled */
      --waline-border-color: var(--border) !important;
      --waline-disable-bg-color: var(--muted) !important;
      --waline-disable-color: var(--foreground-soft) !important;

      /* Special Colors */
      --waline-bq-color: var(--muted) !important;
      --waline-info-bg-color: var(--muted) !important;
      --waline-info-color: var(--foreground-soft) !important;
      --waline-code-bg-color: var(--surface-strong, #1e1e1e) !important;

      /* White/Grey overrides */
      --waline-white: var(--card) !important;
      --waline-light-grey: var(--foreground-soft) !important;
      --waline-dark-grey: var(--foreground) !important;
    }

    /* ===========================================
     * DARK MODE THEME
     * =========================================== */
    html[data-theme="dark"] {
      /* Primary Backgrounds */
      --waline-bg-color: var(--card) !important;
      --waline-bg-color-light: var(--muted) !important;
      --waline-bg-color-hover: var(--primary-soft) !important;

      /* Text Colors */
      --waline-color: var(--foreground) !important;
      --waline-font-color: var(--foreground) !important;

      /* Border & Disabled */
      --waline-border-color: var(--border) !important;
      --waline-disable-bg-color: rgba(128, 128, 128, 0.2) !important;
      --waline-disable-color: var(--foreground-soft) !important;

      /* Special Colors */
      --waline-bq-color: var(--muted) !important;
      --waline-info-bg-color: var(--muted) !important;
      --waline-info-color: var(--foreground-soft) !important;
      --waline-code-bg-color: var(--surface-strong, #0d1117) !important;

      /* White/Grey overrides */
      --waline-white: var(--card) !important;
      --waline-light-grey: var(--foreground-soft) !important;
      --waline-dark-grey: var(--foreground) !important;
    }

    /* ===========================================
     * CONTAINER & PANEL STYLES
     * =========================================== */
    #waline {
      padding-top: 0.5rem;
    }

    /* Main panel */
    #waline .wl-panel {
      background-color: var(--card) !important;
      border-color: var(--border) !important;
    }

    /* Header area - nickname, email, website inputs */
    #waline .wl-header {
      background-color: transparent !important;
    }

    #waline .wl-header-item {
      background-color: var(--surface, rgba(255, 255, 255, 0.72)) !important;
      border-color: var(--border) !important;
    }

    /* Input wrapper */
    #waline .wl-input-wrapper {
      background-color: var(--card) !important;
      border-color: var(--border) !important;
    }

    /* ===========================================
     * INPUT & EDITOR STYLES
     * =========================================== */
    #waline .wl-editor,
    #waline .wl-input {
      min-height: 120px !important;
      background-color: var(--surface-strong, rgba(255, 255, 255, 0.92)) !important;
      border-color: var(--border) !important;
      border-radius: var(--radius-lg, 0.5rem) !important;
      transition:
        border-color 0.15s ease,
        box-shadow 0.15s ease !important;
    }

    #waline .wl-input {
      min-height: auto !important;
    }

    #waline .wl-editor:focus,
    #waline .wl-input:focus {
      border-color: var(--primary) !important;
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 15%, transparent) !important;
      outline: none;
    }

    /* Textarea */
    #waline textarea {
      background-color: var(--surface-strong, rgba(255, 255, 255, 0.92)) !important;
      color: var(--foreground) !important;
    }

    /* ===========================================
     * BUTTON STYLES
     * =========================================== */
    #waline .wl-btn {
      transition:
        background-color 0.15s ease,
        border-color 0.15s ease !important;
      border-radius: var(--radius-md, 0.375rem) !important;
      background-color: var(--surface, rgba(255, 255, 255, 0.72)) !important;
      border: 1px solid var(--border) !important;
      color: var(--foreground) !important;
      cursor: pointer;
    }

    #waline .wl-btn:hover {
      background-color: var(--primary-soft) !important;
      border-color: var(--primary) !important;
    }

    #waline .wl-primary-btn {
      font-weight: 500 !important;
      background-color: var(--primary) !important;
      border-color: var(--primary) !important;
      color: var(--background) !important;
    }

    #waline .wl-primary-btn:hover {
      background-color: var(--primary) !important;
      opacity: 0.9;
    }

    /* ===========================================
     * COMMENT CARD STYLES
     * =========================================== */
    #waline .wl-card {
      border-radius: var(--radius-lg, 0.5rem) !important;
      background-color: var(--card) !important;
      border-color: var(--border) !important;
      transition: background-color 0.15s ease !important;
    }

    #waline .wl-card:hover {
      background-color: var(--card-hover) !important;
    }

    /* Comment content area */
    #waline .wl-content {
      background-color: transparent !important;
    }

    /* Comment meta info */
    #waline .wl-meta {
      color: var(--foreground-soft) !important;
    }

    /* ===========================================
     * AVATAR STYLES
     * =========================================== */
    #waline .wl-avatar {
      border-radius: 50% !important;
    }

    /* ===========================================
     * QUOTE & CODE STYLES
     * =========================================== */
    #waline .wl-quote {
      border-left-color: var(--primary) !important;
      background-color: var(--surface, rgba(255, 255, 255, 0.72)) !important;
      color: var(--foreground) !important;
    }

    #waline .wl-content pre,
    #waline .wl-content code {
      background-color: var(--waline-code-bg-color) !important;
      border-radius: var(--radius-sm, 0.25rem) !important;
    }

    /* ===========================================
     * PAGINATION
     * =========================================== */
    #waline .wl-page-button {
      border-radius: var(--radius-sm, 0.25rem) !important;
      transition:
        background-color 0.15s ease,
        color 0.15s ease !important;
      background-color: var(--surface, rgba(255, 255, 255, 0.72)) !important;
      border: 1px solid var(--border) !important;
      color: var(--foreground) !important;
      cursor: pointer;
    }

    #waline .wl-page-button:hover {
      background-color: var(--primary) !important;
      border-color: var(--primary) !important;
      color: var(--background) !important;
    }

    #waline .wl-page-button.active {
      background-color: var(--primary) !important;
      border-color: var(--primary) !important;
      color: var(--background) !important;
    }

    /* ===========================================
     * ADMIN & BADGE STYLES
     * =========================================== */
    #waline .wl-badge {
      background-color: var(--primary) !important;
      color: var(--background) !important;
    }

    #waline .wl-admin {
      color: var(--primary) !important;
    }
  </style>
</div>