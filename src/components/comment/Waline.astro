---
import { commentConfig, siteConfig } from "@/config";

interface Props {
	path: string;
}

const walineConfig = {
	...commentConfig.waline,
	el: "#waline",
	path: Astro.props.path,
	lang: siteConfig.lang.replace("_", "-"),
	dark: "auto",
};
---

<div id="waline-container" class="waline-container">
	<div id="waline"></div>
</div>

<script is:inline define:vars={{ config: walineConfig }}>
	(function () {
		const WALINE_CONTAINER_ID = "waline-container";
		const WALINE_SCRIPT_URL = "https://unpkg.com/@waline/client@v3/dist/waline.js";
		const WALINE_CSS_URL = "https://unpkg.com/@waline/client@v3/dist/waline.css";
		const ROOT_MARGIN = "200px";

		let observer = null;
		let walineInstance = null;
		let cssLoaded = false;

		function getCurrentPath() {
			const pathname = window.location.pathname;
			return pathname.endsWith("/") && pathname.length > 1
				? pathname.slice(0, -1)
				: pathname;
		}

		function loadCSS() {
			if (cssLoaded || document.getElementById("waline-css")) {
				return;
			}
			const link = document.createElement("link");
			link.id = "waline-css";
			link.rel = "stylesheet";
			link.href = WALINE_CSS_URL;
			document.head.appendChild(link);
			cssLoaded = true;
		}

		function isDark() {
			return (
				document.documentElement.classList.contains("dark") ||
				document.documentElement.getAttribute("data-theme")?.includes("dark")
			);
		}

		async function initWaline() {
			const container = document.getElementById(WALINE_CONTAINER_ID);
			if (!container) {
				return;
			}

			loadCSS();

			// Load Waline client if not yet available
			if (typeof Waline === "undefined") {
				await new Promise((resolve, reject) => {
					if (document.getElementById("waline-script-loaded")) {
						// Script tag exists but may not have executed yet
						const check = setInterval(() => {
							if (typeof Waline !== "undefined") {
								clearInterval(check);
								resolve();
							}
						}, 50);
						setTimeout(() => { clearInterval(check); reject(new Error("timeout")); }, 5000);
						return;
					}
					const script = document.createElement("script");
					script.id = "waline-script-loaded";
					script.src = WALINE_SCRIPT_URL;
					script.async = true;
					script.onload = resolve;
					script.onerror = reject;
					document.head.appendChild(script);
				});
			}

			if (typeof Waline === "undefined") {
				console.warn("[Waline] Client script failed to load");
				return;
			}

			// Destroy previous instance on page transition
			if (walineInstance) {
				walineInstance.destroy();
				walineInstance = null;
			}

			const el = document.getElementById("waline");
			if (!el) {
				return;
			}

			walineInstance = Waline({
				...config,
				el: el,
				path: getCurrentPath(),
				dark: isDark() ? "dark" : "light",
			});
		}

		function cleanup() {
			if (observer) {
				observer.disconnect();
				observer = null;
			}
			if (walineInstance) {
				walineInstance.destroy();
				walineInstance = null;
			}
			if (window.swup?.hooks) {
				window.swup.hooks.off("content:replace", onContentReplace);
			}
		}

		function onContentReplace() {
			setTimeout(setupLazyLoad, 200);
		}

		function setupLazyLoad() {
			const container = document.getElementById(WALINE_CONTAINER_ID);
			if (!container) {
				return;
			}

			observer = new IntersectionObserver(
				(entries) => {
					if (entries[0].isIntersecting) {
						observer.disconnect();
						observer = null;
						initWaline();
					}
				},
				{ rootMargin: ROOT_MARGIN },
			);

			observer.observe(container);
		}

		function setupSwupHooks() {
			if (window.swup?.hooks) {
				window.swup.hooks.on("content:replace", onContentReplace);
			} else {
				document.addEventListener(
					"swup:enable",
					() => {
						if (window.swup?.hooks) {
							window.swup.hooks.on("content:replace", onContentReplace);
						}
					},
					{ once: true },
				);
			}
		}

		// Theme change handler — update Waline dark mode
		const themeObserver = new MutationObserver((mutations) => {
			mutations.forEach((mutation) => {
				if (
					mutation.attributeName === "class" ||
					mutation.attributeName === "data-theme"
				) {
					if (walineInstance) {
						walineInstance.update({
							dark: isDark() ? "dark" : "light",
						});
					}
				}
			});
		});

		themeObserver.observe(document.documentElement, { attributes: true });

		document.addEventListener("mizuki:page:loaded", () => {
			setupLazyLoad();
		});

		window.addEventListener("beforeunload", cleanup);

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", () => {
				setupLazyLoad();
				setupSwupHooks();
			});
		} else {
			setupLazyLoad();
			setupSwupHooks();
		}
	})();
</script>

<style>
	.waline-container {
		min-height: 200px;
	}
</style>
