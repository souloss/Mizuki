---
import { commentConfig, siteConfig } from "@/config";

interface Props {
	path: string;
}

const walineConfig = {
	...commentConfig.waline,
	el: "#waline",
	path: Astro.props.path,
	lang: siteConfig.lang.replace("_", "-"),
	dark: "auto",
};
---

<div id="waline-container" class="waline-container">
	<div id="waline"></div>
</div>

<script is:inline define:vars={{ config: walineConfig }}>
	(function () {
		var WALINE_CONTAINER_ID = "waline-container";
		var WALINE_SCRIPT_URL = "https://unpkg.com/@waline/client@v3/dist/iife/waline.js";
		var WALINE_CSS_URL = "https://unpkg.com/@waline/client@v3/dist/waline.css";
		var ROOT_MARGIN = "200px";

		var observer = null;
		var walineInstance = null;
		var cssLoaded = false;
		var scriptLoaded = false;

		function getCurrentPath() {
			var pathname = window.location.pathname;
			return pathname.endsWith("/") && pathname.length > 1
				? pathname.slice(0, -1)
				: pathname;
		}

		function loadCSS() {
			if (cssLoaded || document.getElementById("waline-css")) {
				return;
			}
			var link = document.createElement("link");
			link.id = "waline-css";
			link.rel = "stylesheet";
			link.href = WALINE_CSS_URL;
			document.head.appendChild(link);
			cssLoaded = true;
		}

		function loadScript() {
			return new Promise(function (resolve, reject) {
				if (scriptLoaded && typeof Waline === "function") {
					resolve();
					return;
				}
				if (document.getElementById("waline-script")) {
					var check = setInterval(function () {
						if (typeof Waline === "function") {
							clearInterval(check);
							scriptLoaded = true;
							resolve();
						}
					}, 50);
					setTimeout(function () {
						clearInterval(check);
						reject(new Error("Waline script load timeout"));
					}, 10000);
					return;
				}
				var script = document.createElement("script");
				script.id = "waline-script";
				script.src = WALINE_SCRIPT_URL;
				script.async = true;
				script.onload = function () {
					scriptLoaded = true;
					resolve();
				};
				script.onerror = function () {
					reject(new Error("Failed to load Waline script"));
				};
				document.head.appendChild(script);
			});
		}

		function isDark() {
			return (
				document.documentElement.classList.contains("dark") ||
				(document.documentElement.getAttribute("data-theme") || "").includes("dark")
			);
		}

		async function initWaline() {
			var container = document.getElementById(WALINE_CONTAINER_ID);
			if (!container) return;

			loadCSS();

			try {
				await loadScript();
			} catch (e) {
				console.error("[Waline]", e);
				return;
			}

			if (typeof Waline !== "function") {
				console.error("[Waline] Waline is not a function");
				return;
			}

			if (walineInstance) {
				walineInstance.destroy();
				walineInstance = null;
			}

			var el = document.getElementById("waline");
			if (!el) return;

			walineInstance = Waline({
				...config,
				el: el,
				path: getCurrentPath(),
				dark: isDark() ? "dark" : "light",
			});
		}

		function cleanup() {
			if (observer) {
				observer.disconnect();
				observer = null;
			}
			if (walineInstance) {
				walineInstance.destroy();
				walineInstance = null;
			}
			if (window.swup && window.swup.hooks) {
				window.swup.hooks.off("content:replace", onContentReplace);
			}
		}

		function onContentReplace() {
			setTimeout(setupLazyLoad, 200);
		}

		function setupLazyLoad() {
			var container = document.getElementById(WALINE_CONTAINER_ID);
			if (!container) return;

			observer = new IntersectionObserver(
				function (entries) {
					if (entries[0].isIntersecting) {
						observer.disconnect();
						observer = null;
						initWaline();
					}
				},
				{ rootMargin: ROOT_MARGIN },
			);
			observer.observe(container);
		}

		function setupSwupHooks() {
			if (window.swup && window.swup.hooks) {
				window.swup.hooks.on("content:replace", onContentReplace);
			} else {
				document.addEventListener(
					"swup:enable",
					function () {
						if (window.swup && window.swup.hooks) {
							window.swup.hooks.on("content:replace", onContentReplace);
						}
					},
					{ once: true },
				);
			}
		}

		// Theme change handler
		var themeObserver = new MutationObserver(function (mutations) {
			mutations.forEach(function (mutation) {
				if (
					mutation.attributeName === "class" ||
					mutation.attributeName === "data-theme"
				) {
					if (walineInstance) {
						walineInstance.update({
							dark: isDark() ? "dark" : "light",
						});
					}
				}
			});
		});
		themeObserver.observe(document.documentElement, { attributes: true });

		document.addEventListener("mizuki:page:loaded", function () {
			setupLazyLoad();
		});

		window.addEventListener("beforeunload", cleanup);

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", function () {
				setupLazyLoad();
				setupSwupHooks();
			});
		} else {
			setupLazyLoad();
			setupSwupHooks();
		}
	})();
</script>

<style>
	.waline-container {
		min-height: 200px;
	}
</style>
