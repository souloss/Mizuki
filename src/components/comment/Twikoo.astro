---
import { commentConfig } from "@/config";

interface Props {
	path: string;
}

const config = {
	...commentConfig.twikoo,
	el: "#tcomment",
	path: Astro.props.path,
};
---

<div id="twikoo-container" class="twikoo-container">
  {/* Twikoo Container */}
  <div id="tcomment" class="not-prose"></div>

  {/* Loading indicator */}
  <div id="twikoo-loading" class="flex items-center justify-center py-8">
    <div class="animate-spin h-8 w-8 border-2 border-primary border-t-transparent rounded-full"></div>
  </div>

  {/* Fallback for disabled JS */}
  <noscript>
    <div class="rounded-lg bg-muted/50 p-4 text-center text-muted-foreground">
      请启用 JavaScript 以查看评论功能。
    </div>
  </noscript>

  <script is:inline define:vars={{ config }}>
    (function () {
      const TWIKOO_CONTAINER_ID = "twikoo-container";
      const TWIKOO_SCRIPT_URL = "/assets/js/twikoo.all.min.js";
      const ROOT_MARGIN = "200px";
      const LOADING_TIMEOUT = 15000;

      let observer = null;
      let twikooLoaded = false;
      let timeoutId = null;
      let initialized = false;

      function hideLoading() {
        const loading = document.getElementById('twikoo-loading');
        if (loading) {
          loading.style.display = 'none';
        }
        if (timeoutId) {
          clearTimeout(timeoutId);
          timeoutId = null;
        }
      }

      function showError(message) {
        const loading = document.getElementById('twikoo-loading');
        if (loading) {
          loading.innerHTML = '<div class="text-center text-muted-foreground">' + message + '</div>';
        }
      }

      function getCurrentPath() {
        const pathname = window.location.pathname;
        return pathname.endsWith("/") && pathname.length > 1
          ? pathname.slice(0, -1)
          : pathname;
      }

      function createTwikooConfig() {
        return {
          el: "#tcomment",
          envId: config.envId,
          path: getCurrentPath(),
          region: config.region || undefined,
          visitorCount: config.visitorCount !== undefined ? config.visitorCount : false,
        };
      }

      async function loadTwikooScript() {
        if (twikooLoaded || document.getElementById("twikoo-script-loaded")) {
          return;
        }
        return new Promise(function (resolve, reject) {
          const script = document.createElement("script");
          script.id = "twikoo-script-loaded";
          script.src = TWIKOO_SCRIPT_URL;
          script.async = true;
          script.onload = function () {
            twikooLoaded = true;
            resolve();
          };
          script.onerror = function () {
            showError('评论组件加载失败，请检查网络');
            reject(new Error('Failed to load Twikoo script'));
          };
          document.head.appendChild(script);
        });
      }

      async function forceStyleReflow() {
        // Twikoo uses Vue/Element UI internally — after init(), the DOM may
        // not be fully stable yet (sub-components render asynchronously).
        // Waiting two animation frames ensures the browser has painted at
        // least once, so all CSS rules (including our @apply overrides in
        // twikoo.css) are matched against the final DOM structure.
        await new Promise(function (r) { requestAnimationFrame(function () { requestAnimationFrame(r); }); });

        const container = document.getElementById(TWIKOO_CONTAINER_ID);
        if (container) {
          // Force a synchronous layout reflow so computed styles are up-to-date
          void container.offsetHeight;
          // Briefly hide then show to eliminate any paint with stale styles
          container.style.opacity = "0.99";
          requestAnimationFrame(function () {
            container.style.opacity = "";
          });
        }
      }

      async function initTwikoo() {
        const commentEl = document.getElementById("tcomment");
        if (!commentEl) {
          return;
        }

        if (!config.envId) {
          showError('评论系统未配置 envId');
          return;
        }

        // Set timeout to force hide loading
        timeoutId = setTimeout(function () {
          hideLoading();
        }, LOADING_TIMEOUT);

        try {
          await loadTwikooScript();

          if (typeof twikoo === "undefined") {
            showError('评论脚本加载失败，请刷新重试');
            return;
          }

          // Clear previous contents only if re-initializing
          if (initialized) {
            commentEl.innerHTML = "";
          }

          const dynamicConfig = createTwikooConfig();
          await twikoo.init(dynamicConfig);
          initialized = true;

          // Wait for Twikoo's internal Vue components to finish rendering,
          // then force a style reflow so our CSS overrides take full effect.
          await forceStyleReflow();

          hideLoading();
        } catch (error) {
          showError('评论加载失败，请刷新重试');
        }
      }

      function cleanup() {
        if (observer) {
          observer.disconnect();
          observer = null;
        }
        if (window.swup && window.swup.hooks) {
          window.swup.hooks.off("content:replace", initTwikoo);
        }
        initialized = false;
      }

      function setupLazyLoad() {
        const container = document.getElementById(TWIKOO_CONTAINER_ID);
        if (!container) {
          return;
        }

        observer = new IntersectionObserver(
          function (entries) {
            if (entries[0].isIntersecting) {
              observer.disconnect();
              observer = null;
              initTwikoo();
            }
          },
          { rootMargin: ROOT_MARGIN },
        );

        observer.observe(container);
      }

      function setupSwupHooks() {
        if (window.swup && window.swup.hooks) {
          window.swup.hooks.on("content:replace", function () {
            setTimeout(setupLazyLoad, 200);
          });
        } else {
          document.addEventListener("swup:enable", function () {
            if (window.swup && window.swup.hooks) {
              window.swup.hooks.on("content:replace", function () {
                setTimeout(setupLazyLoad, 200);
              });
            }
          }, { once: true });
        }
      }

      // Astro page lifecycle events
      document.addEventListener("astro:page-load", function () {
        setupLazyLoad();
        setupSwupHooks();
      });

      document.addEventListener("astro:before-swap", cleanup);

      document.addEventListener("mizuki:page:loaded", function () {
        setupLazyLoad();
      });

      window.addEventListener("beforeunload", cleanup);

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", function () {
          setupLazyLoad();
          setupSwupHooks();
        });
      } else {
        setupLazyLoad();
        setupSwupHooks();
      }
    })();
  </script>

  <style>
    .twikoo-container {
      min-height: 200px;
    }
  </style>
</div>