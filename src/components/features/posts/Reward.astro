---
import { Icon } from "astro-icon/components"
import { siteConfig } from "@/config"
import { i18n } from "@/i18n/translation"
import I18nKey from "@/i18n/i18nKey"

interface Props {
  class?: string
}

const { class: className = "" } = Astro.props
---

{siteConfig.featurePages.sponsor && (
  <a
    href="/sponsor/"
    class={`reward-link inline-flex items-center gap-1.5 px-4 py-2 rounded-lg
      bg-[var(--btn-regular-bg)] hover:bg-[var(--btn-hover-bg)]
      text-[var(--btn-content)] text-sm
      transition-colors duration-150 ${className}`}
  >
    <Icon name="material-symbols:favorite-rounded" class="text-base" />
    <span>{i18n(I18nKey.reward)}</span>
  </a>
)}
