---
import { rewardConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

const { enable, message, AliPay, WeChat } = rewardConfig;

if (!enable) {return;}

const displayMessage = message || i18n(I18nKey.rewardMessage);
const hasAliPay = !!AliPay;
const hasWeChat = !!WeChat;
---

<section class="reward-container onload-animation mb-6 rounded-xl">
  <p class="reward-message text-sm text-black/50 dark:text-white/50 text-center py-2">
    {displayMessage}
  </p>
  <div class="reward-list flex items-center justify-center gap-4 py-3">
    {hasAliPay && (
      <span class="reward-btn alipay relative cursor-pointer select-none transition-all duration-150
        hover:-translate-y-0.5 hover:shadow-md">
        <span class="reward-btn-label">{i18n(I18nKey.rewardAliPay)}</span>
        <img
          class="reward-qrcode absolute left-1/2 -translate-x-1/2 bottom-full opacity-0 pointer-events-none
            transition-all duration-150 max-w-[258px] w-[calc(100vw-1rem)] rounded-xl aspect-[6/8] bg-cover z-10"
          src={AliPay}
          alt={i18n(I18nKey.rewardAliPay)}
        />
      </span>
    )}
    {hasWeChat && (
      <span class="reward-btn wechat relative cursor-pointer select-none transition-all duration-150
        hover:-translate-y-0.5 hover:shadow-md">
        <span class="reward-btn-label">{i18n(I18nKey.rewardWeChat)}</span>
        <img
          class="reward-qrcode absolute left-1/2 -translate-x-1/2 bottom-full opacity-0 pointer-events-none
            transition-all duration-150 max-w-[258px] w-[calc(100vw-1rem)] rounded-xl aspect-[6/8] bg-cover z-10"
          src={WeChat}
          alt={i18n(I18nKey.rewardWeChat)}
        />
      </span>
    )}
  </div>
</section>

<style>
  .reward-container {
    background: var(--card-bg);
  }

  .reward-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.375rem 0.75rem;
    height: 2rem;
    border-radius: 0.375rem;
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    gap: 0.25rem;
  }

  .reward-btn.alipay {
    background: #00a0e8;
  }

  .reward-btn.wechat {
    background: #1aad19;
  }

  .reward-btn:hover .reward-qrcode {
    opacity: 1;
    pointer-events: auto;
    transform: translate(-50%, -1rem);
  }

  /* Invisible click area for hover target */
  .reward-btn::before {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: 100%;
    width: calc(100vw - 1rem);
    max-width: 258px;
    height: 100%;
    pointer-events: none;
  }

  .reward-btn:hover::before {
    pointer-events: auto;
  }

  .reward-qrcode {
    object-fit: cover;
  }

  /* Dark mode adjustments */
  :global(.dark) .reward-container {
    background: var(--card-bg);
  }
</style>