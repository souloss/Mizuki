---
interface Props {
	currentLang: string;
	defaultLang: string;
	availableLangs: string[];
	currentPagePath: string;
	docSlug: string;
}

const { currentLang, defaultLang, availableLangs, currentPagePath, docSlug } = Astro.props;

// Language display names
const langNames: Record<string, string> = {
	"zh_CN": "中文",
	"en": "English",
	"ja": "日本語",
	"ko": "한국어",
	"fr": "Français",
	"de": "Deutsch",
	"es": "Español",
	"ru": "Русский",
};

// Build URL for a target language
// currentPagePath is the raw page.id (e.g., "mizuki/en/guide/intro.md")
function getLangUrl(targetLang: string): string {
	let cleanPath = currentPagePath.replace(/\.(md|mdx)$/, "");

	// Strip docSlug prefix (e.g., "mizuki/" -> "")
	if (cleanPath.startsWith(docSlug + "/")) {
		cleanPath = cleanPath.slice(docSlug.length + 1);
	} else if (cleanPath === docSlug) {
		cleanPath = "";
	}

	// Strip current lang prefix if present
	if (currentLang && currentLang !== defaultLang) {
		if (cleanPath === currentLang) {
			cleanPath = "";
		} else if (cleanPath.startsWith(currentLang + "/")) {
			cleanPath = cleanPath.slice(currentLang.length + 1);
		}
	}

	// Build URL for target language
	if (targetLang === defaultLang) {
		// Default language: no lang prefix
		return cleanPath === "" ? `/docs/${docSlug}/` : `/docs/${docSlug}/${cleanPath}/`;
	} else {
		// Non-default language: add lang prefix
		return `/docs/${docSlug}/${targetLang}/${cleanPath === "" ? "" : cleanPath + "/"}`;
	}
}

// Only show if there are multiple languages
if (availableLangs.length <= 1) {return;}
---

<div class="docs-lang-switcher">
	{availableLangs.map((lang) => (
		<a
			href={getLangUrl(lang)}
			class:list={[
				"docs-lang-switcher-item",
				{ "docs-lang-switcher-active": lang === currentLang },
			]}
		>
			{langNames[lang] || lang}
		</a>
	))}
</div>

<style>
	.docs-lang-switcher {
		display: flex;
		gap: 0.25rem;
		padding: 0.5rem 0.75rem;
		border-bottom: 1px solid var(--line-divider);
		margin-bottom: 0.5rem;
	}

	.docs-lang-switcher-item {
		padding: 0.25rem 0.5rem;
		font-size: 0.75rem;
		border-radius: 0.375rem;
		color: var(--text-50);
		text-decoration: none;
		transition: all 0.2s;
	}

	.docs-lang-switcher-item:hover {
		background: var(--toc-btn-hover);
		color: var(--text-75);
	}

	.docs-lang-switcher-active {
		background: var(--toc-btn-hover);
		color: var(--primary);
		font-weight: 500;
	}
</style>
