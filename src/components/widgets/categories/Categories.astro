---
import { Icon } from "astro-icon/components";

import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import { getCategoryList } from "../../../utils/content-utils";
import { widgetManager } from "../../../utils/widget-manager";
import WidgetLayout from "../common/WidgetLayout.astro";

const allCategories = await getCategoryList();

const COLLAPSED_HEIGHT = "7.5rem";

// 使用统一的组件管理器检查是否应该折叠
const categoriesComponent = widgetManager
	.getConfig()
	.properties.find((p) => p.type === "categories");
const isCollapsed = categoriesComponent
	? widgetManager.isCollapsed(categoriesComponent, allCategories.length)
	: false;

// 从 customProps 读取 topN 配置，0 或未设置表示显示全部
const topN: number = (categoriesComponent?.customProps?.topN as number) || 0;
const sortedCategories = [...allCategories].sort((a, b) => b.count - a.count);
const categories = topN > 0 ? sortedCategories.slice(0, topN) : sortedCategories;
const hasMore = topN > 0 && allCategories.length > topN;

const CAT_HUES = [0, 25, 50, 85, 140, 175, 210, 255, 290, 330];

function getCatHue(name: string): number {
	let hash = 0;
	for (const ch of name) {
		hash = ((hash << 5) - hash + ch.charCodeAt(0)) | 0;
	}
	return CAT_HUES[Math.abs(hash) % CAT_HUES.length];
}

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---

<WidgetLayout
	name={i18n(I18nKey.categories)}
	id="categories"
	isCollapsed={isCollapsed}
	collapsedHeight={COLLAPSED_HEIGHT}
	class={className}
	style={style}
>
	<div class="flex flex-wrap gap-2">
		{categories.map((c) => {
			const hue = getCatHue(c.name);
			return (
				<a
					href={c.url}
					aria-label={`View all posts in the ${c.name.trim()} category`}
					class="cat-capsule"
					style={`--cat-hue: ${hue}`}
				>
					<Icon name="material-symbols:folder-outline" class="cat-capsule-icon" />
					{c.name.trim()}
					<span class="cat-capsule-count">{c.count}</span>
				</a>
			);
		})}
	</div>
	<a
		href="/categories/"
		class="mt-3 text-sm text-black/50 dark:text-white/50 hover:text-[var(--primary)] transition-colors flex items-center gap-1"
	>
		{hasMore ? `${i18n(I18nKey.viewAll)} (${allCategories.length})` : i18n(I18nKey.viewAll)}
		<Icon name="material-symbols:arrow-forward-rounded" class="text-sm" />
	</a>
</WidgetLayout>

<style is:global>
.cat-capsule {
	display: inline-flex;
	align-items: center;
	gap: 0.375rem;
	padding: 0.375rem 0.75rem;
	border-radius: 9999px;
	background: hsl(var(--cat-hue), 70%, 94%);
	color: hsl(var(--cat-hue), 55%, 38%);
	font-size: 0.75rem;
	font-weight: 500;
	text-decoration: none;
	transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}

.cat-capsule:hover {
	transform: scale(1.06);
	box-shadow: 0 2px 8px hsla(var(--cat-hue), 60%, 60%, 0.2);
	background: hsl(var(--cat-hue), 70%, 88%);
}

.cat-capsule-icon {
	font-size: 0.875rem;
}

.cat-capsule-count {
	font-size: 0.65rem;
	opacity: 0.5;
	font-weight: 400;
}

.dark .cat-capsule {
	background: hsl(var(--cat-hue), 30%, 18%);
	color: hsl(var(--cat-hue), 50%, 72%);
}

.dark .cat-capsule:hover {
	background: hsl(var(--cat-hue), 35%, 24%);
	box-shadow: 0 2px 8px hsla(var(--cat-hue), 50%, 30%, 0.2);
}
</style>