---
/**
 * AnalyticsScripts.astro
 * 第三方分析脚本组件 - 延迟加载优化
 *
 * 包含:
 * - Google Tag Manager (GTM)
 * - Microsoft Clarity (可选，通过 thirdPartyAnalytics 配置控制)
 * - Umami Analytics (可选，通过 analytics.umamiAnalytics 配置控制)
 *
 * 使用 requestIdleCallback 延迟加载以优化性能
 */

interface Props {
	gtmId?: string;
	thirdPartyAnalytics?: {
		enable: boolean;
		clarityId?: string;
	};
	umamiAnalytics?: {
		websiteId?: string;
		scriptUrl?: string;
		trackOutboundLinks?: boolean;
		collectWebVitals?: boolean;
		relpays?: {
			enabled?: boolean;
			sampleRate?: number;
			maskLevel?: "moderate" | "strict";
			maxDuration?: number;
			blockSelector?: string;
		};
	};
}

const {
	gtmId = "GTM-KRX3XGVH",
	thirdPartyAnalytics = { enable: false, clarityId: "" },
	umamiAnalytics,
} = Astro.props;

const clarityEnable =
	thirdPartyAnalytics.enable && thirdPartyAnalytics.clarityId;
const umamiEnable = umamiAnalytics && umamiAnalytics.websiteId && umamiAnalytics.scriptUrl;
---

<!-- 第三方分析脚本 - 仅在用户交互后延迟加载 -->
<script
	is:inline
	define:vars={{
		gtmId,
		clarityEnable,
		clarityId: thirdPartyAnalytics.clarityId || "",
		umamiEnable,
		umamiWebsiteId: umamiAnalytics?.websiteId || "",
		umamiScriptUrl: umamiAnalytics?.scriptUrl || "",
		umamiTrackOutboundLinks: umamiAnalytics?.trackOutboundLinks ?? true,
		umamiCollectWebVitals: umamiAnalytics?.collectWebVitals ?? false,
		umamiRelpaysEnabled: umamiAnalytics?.relpays?.enabled ?? false,
		umamiRelpaysSampleRate: umamiAnalytics?.relpays?.sampleRate ?? 0.15,
		umamiRelpaysMaskLevel: umamiAnalytics?.relpays?.maskLevel ?? "moderate",
		umamiRelpaysMaxDuration: umamiAnalytics?.relpays?.maxDuration ?? 300000,
		umamiRelpaysBlockSelector: umamiAnalytics?.relpays?.blockSelector || "",
	}}
>
	(function () {
		// 标记脚本是否已加载
		window.analyticsLoaded = window.analyticsLoaded || false;

		function loadAnalytics() {
			if (window.analyticsLoaded) {
				return;
			}
			window.analyticsLoaded = true;

			// Google Tag Manager
			(function (w, d, s, l, i) {
				w[l] = w[l] || [];
				w[l].push({
					"gtm.start": new Date().getTime(),
					event: "gtm.js",
				});
				const f = d.getElementsByTagName(s)[0],
					j = d.createElement(s);
				j.async = true;
				j.src = "https://www.googletagmanager.com/gtm.js?id=" + i;
				f.parentNode.insertBefore(j, f);
			})(window, document, "script", "dataLayer", gtmId);

			// Clarity (仅在启用时加载)
			if (clarityEnable && clarityId) {
				(function (c, l, a, r, i, t, y) {
					c[a] =
						c[a] ||
						function () {
							(c[a].q = c[a].q || []).push(arguments);
						};
					t = l.createElement(r);
					t.async = 1;
					t.src = "https://www.clarity.ms/tag/" + i;
					y = l.getElementsByTagName(r)[0];
					y.parentNode.insertBefore(t, y);
				})(window, document, "clarity", "script", clarityId);
			}

			// Umami (仅在启用时加载)
			if (umamiEnable && umamiScriptUrl && umamiWebsiteId) {
				const umamiScript = document.createElement("script");
				umamiScript.defer = true;
				umamiScript.src = umamiScriptUrl;
				umamiScript.setAttribute("data-website-id", umamiWebsiteId);
				if (umamiTrackOutboundLinks) {
					umamiScript.setAttribute("data-track-outbound-links", "true");
				}
				if (umamiCollectWebVitals) {
					umamiScript.setAttribute("data-collect-web-vitals", "true");
				}
				if (umamiRelpaysEnabled) {
					umamiScript.setAttribute("data-relpays-enabled", "true");
					umamiScript.setAttribute("data-relpays-sample-rate", umamiRelpaysSampleRate);
					umamiScript.setAttribute("data-relpays-mask-level", umamiRelpaysMaskLevel);
					umamiScript.setAttribute("data-relpays-max-duration", umamiRelpaysMaxDuration);
					if (umamiRelpaysBlockSelector) {
						umamiScript.setAttribute("data-relpays-block-selector", umamiRelpaysBlockSelector);
					}
				}
				document.head.appendChild(umamiScript);
			}
		}

		// 仅在用户交互后加载分析脚本，减少初始页面加载负担
		const events = [
			"scroll",
			"mousemove",
			"keydown",
			"touchstart",
			"click",
		];
		let loaded = false;

		function onInteraction() {
			if (loaded) {
				return;
			}
			loaded = true;
			events.forEach(function (event) {
				window.removeEventListener(event, onInteraction);
			});
			loadAnalytics();
		}

		events.forEach(function (event) {
			window.addEventListener(event, onInteraction, {
				once: true,
				passive: true,
			});
		});

		// 备用：如果用户 10 秒内没有交互，则在 idle 时加载
		setTimeout(function () {
			if (!loaded) {
				loadAnalytics();
			}
		}, 10000);
	})();
</script>
