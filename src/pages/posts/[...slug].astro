---
import path from "node:path";

import Comment from "@components/comment/index.astro";
import {
	LastModified,
	PostMeta,
	PostNavigation,
	RandomPosts,
	RelatedPosts,
} from "@components/features/posts";
import { ReadingTime, WordCount } from "@components/features/posts/atoms";
import RepostNotice from "@components/features/posts/RepostNotice.astro";
import SeriesNav from "@components/features/posts/SeriesNav.astro";
import License from "@components/misc/License.astro";
import Markdown from "@components/misc/Markdown.astro";
import SharePoster from "@components/misc/SharePoster.svelte";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getRelatedPosts, getSortedPosts } from "@utils/content-utils";
import { hasCustomPermalink, initPostIdMap } from "@utils/permalink-utils";
import { getPostPublicDescription } from "@utils/post-card-content";
import { getFileDirFromPath, getPostUrl, removeFileExtension } from "@utils/url-utils";
import { getImage } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { Icon } from "astro-icon/components";
import {
	licenseConfig,
	permalinkConfig,
	randomPostsConfig,
	relatedPostsConfig,
	sponsorConfig,
} from "src/config";

import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

import Image from "../../components/atoms/Image/Image.astro";
import Encryptor from "../../components/features/auth/Encryptor.astro";
import { profileConfig, siteConfig } from "../../config";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";

export async function getStaticPaths() {
	const blogEntries = await getSortedPosts();

	// 初始化文章 ID 映射（用于 %post_id% 占位符）
	initPostIdMap(blogEntries);

	const paths: {
		params: { slug: string };
		props: { entry: CollectionEntry<"posts"> };
	}[] = [];

	for (const entry of blogEntries) {
		// 将 id 转换为 slug（移除扩展名）以匹配路由参数
		const defaultSlug = removeFileExtension(entry.id);

		// 如果文章有自定义 permalink，不在 /posts/ 下创建路径
		// 而是通过根目录的 [permalink].astro 处理
		if (hasCustomPermalink(entry)) {
			// 仍然需要在 /posts/ 下创建默认路径以便兼容旧链接
			paths.push({
				params: { slug: defaultSlug },
				props: { entry },
			});
			continue;
		}

		// 如果全局 permalink 功能启用，不在 /posts/ 下创建路径
		// 而是通过根目录的 [permalink].astro 处理
		if (permalinkConfig.enable) {
			// 仍然保留默认 slug 路径以便兼容旧链接
			paths.push({
				params: { slug: defaultSlug },
				props: { entry },
			});
		} else {
			// 全局 permalink 功能未启用
			// 为每篇文章创建默认的 slug 路径
			paths.push({
				params: { slug: defaultSlug },
				props: { entry },
			});

			// 如果文章有 slug 字段，创建基于 slug 的路径（目录保持原样，只替换文件名）
			// 注意：Astro v5 的 entry.id 是 slugified 的（不含中文/目录），
			// 需要从 entry.filePath 提取目录部分
			if (entry.data.slug) {
				let dir = "";
				if (entry.filePath) {
					// filePath 格式: "src/content/posts/subdir/filename.md"
					// 提取 "src/content/posts/" 之后的目录部分
					const relativePath = entry.filePath.replace(/^src\/content\/posts\//, "");
					const lastSlashIndex = relativePath.lastIndexOf("/");
					dir = lastSlashIndex >= 0 ? relativePath.substring(0, lastSlashIndex + 1) : "";
				}
				const slugPath = `${dir}${entry.data.slug}`;
				// 避免与默认路径重复
				if (slugPath !== defaultSlug) {
					paths.push({
						params: { slug: slugPath },
						props: { entry },
					});
				}
			}

			// 如果文章有 alias，也创建对应的路径
			if (entry.data.alias) {
				// 移除开头的斜杠和结尾的斜杠
				// 同时移除可能的 "posts/" 前缀，避免重复
				let alias = entry.data.alias
					.replace(/^\/+/, "")
					.replace(/\/+$/, "");
				if (alias.startsWith("posts/")) {
					alias = alias.replace(/^posts\//, "");
				}
				paths.push({
					params: { slug: alias },
					props: { entry },
				});
			}
		}
	}

	return paths;
}

const { entry } = Astro.props;

// Compute canonical URL for SEO - prefer slug-based URL when available
let canonicalUrl: string | undefined;
if (entry.data.slug) {
	let dir = "";
	if (entry.filePath) {
		const relativePath = entry.filePath.replace(/^src\/content\/posts\//, "");
		const lastSlashIndex = relativePath.lastIndexOf("/");
		dir = lastSlashIndex >= 0 ? relativePath.substring(0, lastSlashIndex + 1) : "";
	}
	const canonicalPath = `/posts/${dir}${entry.data.slug}/`;
	canonicalUrl = Astro.site ? new URL(canonicalPath, Astro.site).toString() : undefined;
} else if (entry.data.alias) {
	const alias = entry.data.alias.replace(/^\/+/, "").replace(/\/+$/, "");
	const canonicalPath = `/posts/${alias}/`;
	canonicalUrl = Astro.site ? new URL(canonicalPath, Astro.site).toString() : undefined;
}

// 跳转逻辑：如果 redirect 或 repost.redirect 存在，直接重定向到目标页面
const redirectUrl = entry.data.redirect || entry.data.repost?.redirect;
if (redirectUrl) {
	return Astro.redirect(redirectUrl);
}

const { Content, headings } = await render(entry);
const { remarkPluginFrontmatter } = await render(entry);

// 获取相关文章
const relatedPosts = relatedPostsConfig.enable
	? await getRelatedPosts(entry, relatedPostsConfig.maxCount)
	: [];

// Process cover image, for both OG and SharePoster
let ogCoverUrl: string | undefined;
let posterCoverUrl = entry.data.image;

if (entry.data.image) {
	const isLocal = !(
		entry.data.image.startsWith("/") ||
		entry.data.image.startsWith("http") ||
		entry.data.image.startsWith("https") ||
		entry.data.image.startsWith("data:")
	);
	if (isLocal) {
		const basePath = getFileDirFromPath(entry.filePath || "");
		const files = import.meta.glob<ImageMetadata>("../../**", {
			import: "default",
		});
		const normalizedPath = path
			.normalize(path.join("../../", basePath, entry.data.image))
			.replace(/\\/g, "/");
		const file = files[normalizedPath];
		if (file) {
			const img = await file();
			posterCoverUrl = img.src;

			// Resize for OG
			const ogImage = await getImage({
				src: img,
				width: 1200,
				format: "jpeg",
				quality: 80,
			});
			ogCoverUrl = ogImage.src;
		}
	} else if (entry.data.image.startsWith("http")) {
		// Retain the original URL for OG
		ogCoverUrl = entry.data.image;

		// Convert to base64 only for poster
		try {
			const response = await fetch(entry.data.image);
			const arrayBuffer = await response.arrayBuffer();
			const base64 = Buffer.from(arrayBuffer).toString("base64");
			const contentType =
				response.headers.get("content-type") || "image/jpeg";
			posterCoverUrl = `data:${contentType};base64,${base64}`;
		} catch {
			posterCoverUrl = entry.data.image;
		}
	} else {
		ogCoverUrl = entry.data.image; // absolute path like "/images/foo.png"
	}
}

// Process avatar image for SharePoster
let posterAvatarUrl = profileConfig.avatar;
if (profileConfig.avatar) {
	const isLocal = !(
		profileConfig.avatar.startsWith("/") ||
		profileConfig.avatar.startsWith("http") ||
		profileConfig.avatar.startsWith("https") ||
		profileConfig.avatar.startsWith("data:")
	);
	if (isLocal) {
		const files = import.meta.glob<ImageMetadata>("../../**", {
			import: "default",
		});
		const normalizedPath = path
			.normalize(path.join("../../", profileConfig.avatar))
			.replace(/\\/g, "/");
		const file = files[normalizedPath];
		if (file) {
			const img = await file();
			posterAvatarUrl = img.src;
		}
	}
}

// 判断是否为加密文章
const isEncrypted = !!(entry.data.encrypted && entry.data.password);
const publicDescription = getPostPublicDescription(
	entry.data,
	entry.data.title,
);

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: entry.data.title,
	description: publicDescription,
	keywords: entry.data.tags,
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	inLanguage: entry.data.lang
		? entry.data.lang.replace("_", "-")
		: siteConfig.lang.replace("_", "-"),
	// TODO include cover image here
};
---

<MainGridLayout
	banner={entry.data.image}
	title={entry.data.title}
	description={publicDescription}
	lang={entry.data.lang}
	setOGTypeArticle={true}
	postSlug={entry.id}
	headings={headings}
	coverImage={ogCoverUrl}
	canonicalUrl={canonicalUrl}
	pageOverlayTitle={entry.data.title}
	pageOverlayDate={entry.data.published ? formatDateToYYYYMMDD(entry.data.published) : undefined}
	pageOverlayCategory={entry.data.category ?? undefined}
	pageOverlayWords={remarkPluginFrontmatter.words ? String(remarkPluginFrontmatter.words) : undefined}
>
	<script
		is:inline
		slot="head"
		type="application/ld+json"
		set:html={JSON.stringify(jsonLd)}
	/>
	<!-- 引入右侧边栏布局管理器 -->
	<script>
		import("../../scripts/right-sidebar-layout.js");
	</script>
	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4"
	>
		<div
			id="post-container"
			class:list={[
				"card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full ",
				{},
			]}
		>
			<!-- word count and reading time -->
			<div
				class="flex flex-row text-black/30 dark:text-white/30 gap-5 mb-3 transition onload-animation"
			>
				<div class="flex flex-row items-center">
					<WordCount
						words={remarkPluginFrontmatter.words}
						variant="card"
					/>
				</div>
				<div class="flex flex-row items-center">
					<ReadingTime
						minutes={remarkPluginFrontmatter.minutes}
						variant="card"
					/>
				</div>
			</div>

			<!-- title -->
			<div class="relative onload-animation">
				<div
					data-pagefind-body
					data-pagefind-weight="10"
					data-pagefind-meta="title"
					class="transition w-full block font-bold mb-3
                    text-3xl md:text-[2.25rem]/[2.75rem]
                    text-black/90 dark:text-white/90
                    md:before:w-1 before:h-5 before:rounded-md before:bg-[var(--primary)]
                    before:absolute before:top-[0.75rem] before:left-[-1.125rem]"
				>
					{entry.data.title}
				</div>
			</div>

			<!-- metadata -->
			<div class="onload-animation">
				<PostMeta
					className="mb-5"
					published={entry.data.published}
					updated={entry.data.updated}
					tags={entry.data.tags}
					category={entry.data.category || undefined}
					id={entry.id}
					showEncrypted={isEncrypted}
				/>
				{
					(!entry.data.image ||
						(entry.data.image &&
							!siteConfig.showCoverInContent)) && (
						<div class="mt-4 border-[var(--line-divider)] border-dashed border-b-[1px] mb-5" />
					)
				}
			</div>

			<!-- always show cover as long as it has one -->

			{
				entry.data.image && siteConfig.showCoverInContent && (
					<>
						<div class="mt-4" />
						<Image
							id="post-cover"
							src={entry.data.image}
							basePath={getFileDirFromPath(entry.filePath || "")}
							class="mb-8 rounded-xl banner-container onload-animation"
							widths={[640, 1024, 1536, 2048]}
							sizes="(max-width: 768px) 100vw, (max-width: 1200px) 80vw, 1200px"
						/>
					</>
				)
			}

			<!-- Repost notice -->
			{entry.data.repost && (
				<RepostNotice
					originalAuthor={entry.data.repost.originalAuthor}
					originalUrl={entry.data.repost.originalUrl}
					originalTitle={entry.data.repost.originalTitle}
					originalSite={entry.data.repost.originalSite}
				/>
			)}

			{
				isEncrypted ? (
					<Encryptor
						password={entry.data.password}
						slug={entry.id}
						hint={entry.data.passwordHint}
					>
						<Markdown class="mb-6 markdown-content onload-animation">
							<Content />
						</Markdown>
					</Encryptor>
				) : (
					<Markdown class="mb-6 markdown-content onload-animation">
						<Content />
					</Markdown>
				)
			}

			<!-- Series navigation -->
			{entry.data.series && (
				<SeriesNav
					seriesName={entry.data.series}
					currentSlug={removeFileExtension(entry.id)}
				/>
			)}

			{/* 赞助按钮 & 分享按钮 */}
			{
				(siteConfig.sharePoster || (sponsorConfig.showButtonInPost !== false && siteConfig.featurePages?.sponsor)) && (
					<div class:list={["mb-6 rounded-xl onload-animation", { "encrypted-hidden": isEncrypted }]}>
						<div class="p-6 bg-[var(--license-block-bg)] rounded-xl">
							<div class="flex flex-col sm:flex-row items-center justify-between gap-4">
								<div class="flex items-center gap-3 flex-1">
									<div class="h-12 w-12 rounded-lg bg-[var(--primary)] flex items-center justify-center text-white dark:text-black/70 shrink-0">
										<Icon name={sponsorConfig.showButtonInPost !== false && siteConfig.featurePages?.sponsor ? "material-symbols:favorite" : "material-symbols:share"} class="text-2xl" />
									</div>
									<div>
										<h3 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-1">
											{i18n(sponsorConfig.showButtonInPost !== false && siteConfig.featurePages?.sponsor ? I18nKey.sponsorButton : I18nKey.shareOnSocial)}
										</h3>
										<p class="text-sm text-neutral-600 dark:text-neutral-400">
											{i18n(sponsorConfig.showButtonInPost !== false && siteConfig.featurePages?.sponsor ? I18nKey.sponsorButtonText : I18nKey.shareOnSocialDescription)}
										</p>
									</div>
								</div>
								<div class="flex items-center gap-3">
									{
										siteConfig.sharePoster && (
											<SharePoster
												client:only="svelte"
												title={entry.data.title}
												author={profileConfig.name}
												description={entry.data.description || entry.data.title}
												pubDate={formatDateToYYYYMMDD(entry.data.published)}
												coverImage={posterCoverUrl}
												url={Astro.url.href}
												siteTitle={siteConfig.title}
												avatar={posterAvatarUrl}
											/>
										)
									}
									{
										sponsorConfig.showButtonInPost !== false && siteConfig.featurePages?.sponsor && (
											<a
												href="/sponsor/"
												class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--primary)] text-white dark:text-black/70 rounded-lg font-medium hover:bg-[var(--primary)]/80 hover:scale-105 active:scale-95 transition-all whitespace-nowrap"
											>
												<span>{i18n(I18nKey.sponsor)}</span>
												<Icon name="fa7-solid:arrow-right" class="text-sm" />
											</a>
										)
									}
								</div>
							</div>
						</div>
					</div>
				)
			}

			{
				licenseConfig.enable && (
					<div
						id="license-component"
						class:list={[
							"encrypted-hidden-wrapper",
							{ "encrypted-hidden": isEncrypted },
						]}
					>
						<License
							title={entry.data.title}
							id={entry.id}
							pubDate={entry.data.published}
							author={entry.data.author}
							sourceLink={entry.data.sourceLink}
							licenseName={entry.data.licenseName}
							licenseUrl={entry.data.licenseUrl}
							class="mb-6 rounded-xl license-container onload-animation"
						/>
					</div>
				)
			}
		</div>
	</div>


	<!-- 评论 -->
	<Comment post={entry} />

	{
		siteConfig.showLastModified && (
			<LastModified
				updatedDate={entry.data.updated || entry.data.published}
			/>
		)
	}

	<PostNavigation
		prevSlug={entry.data.nextSlug}
		prevTitle={entry.data.nextTitle}
		nextSlug={entry.data.prevSlug}
		nextTitle={entry.data.prevTitle}
	/>

	<!-- 相关文章与随机文章 -->
	{
		(relatedPostsConfig.enable || randomPostsConfig.enable) && (
			<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
				{relatedPostsConfig.enable && relatedPosts.length > 0 && (
					<RelatedPosts relatedPosts={relatedPosts} />
				)}
				{randomPostsConfig.enable && (
					<RandomPosts
						excludeIds={[entry.id]}
						maxCount={randomPostsConfig.maxCount}
					/>
				)}
			</div>
		)
	}
</MainGridLayout>
