---
import { getEntry, render } from "astro:content";
import Comment from "@components/comment/index.astro";
import { PageHeader } from "@components/features/page-header";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";

import { commentConfig, siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

export const prerender = true;

// Check if guestbook page is enabled in config
if (!siteConfig.featurePages.guestbook) {
	return Astro.redirect("/404/");
}

const guestbookPost = await getEntry("spec", "guestbook");
const { Content } = guestbookPost
	? await render(guestbookPost)
	: { Content: () => {} };

// Check if comments are enabled
const isCommentEnabled = commentConfig.enable;

const title = i18n(I18nKey.guestbook);
const subtitle = i18n(I18nKey.guestbookSubtitle);
---

<MainGridLayout title={title} description={subtitle}>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4">
		<div class="card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full">
			<PageHeader
				title={title}
				subtitle={subtitle}
				icon="material-symbols:chat"
			/>

			{guestbookPost && (
				<>
					<div class="mt-4 border-[var(--line-divider)] border-dashed border-b-[1px] mb-6" />
					<Markdown class="mb-6">
						<Content />
					</Markdown>
				</>
			)}
		</div>
	</div>

	{/* Comment section */}
	<div class="mt-4">
		{isCommentEnabled ? (
			<Comment path="/guestbook/" />
		) : (
			<div class="card-base px-6 md:px-9 py-6 relative">
				<div class="text-center py-8 text-[var(--content-meta)]">
					<div class="w-16 h-16 mx-auto mb-4 rounded-full bg-[var(--btn-regular-bg)] flex items-center justify-center">
						<svg class="w-8 h-8 text-[var(--primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
						</svg>
					</div>
					<p class="text-base mb-2 font-medium">{i18n(I18nKey.commentNotConfigured)}</p>
					<p class="text-sm opacity-75">
						{i18n(I18nKey.commentNotConfiguredHint)}
					</p>
				</div>
			</div>
		)}
	</div>
</MainGridLayout>
