---
import CategoryBar from "@components/features/posts/CategoryBar.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsList } from "@utils/content-utils";

import { siteConfig } from "../config";

const sortedPostsList = await getSortedPostsList();

const showCategoryBar = siteConfig.postListLayout.categoryBar?.enable ?? false;

// Sort by published date descending (ignore pinned)
const allPosts = sortedPostsList
	.slice()
	.sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

// Group by year
const grouped: Record<number, typeof allPosts> = {};
for (const post of allPosts) {
	const year = post.data.published.getFullYear();
	if (!grouped[year]) {
		grouped[year] = [];
	}
	grouped[year].push(post);
}

const groups = Object.keys(grouped)
	.map((yearStr) => ({
		year: Number.parseInt(yearStr, 10),
		posts: grouped[Number.parseInt(yearStr, 10)],
	}))
	.sort((a, b) => b.year - a.year);

function formatDate(date: Date) {
	const month = (date.getMonth() + 1).toString().padStart(2, "0");
	const day = date.getDate().toString().padStart(2, "0");
	return `${month}-${day}`;
}

function formatTag(tagList: string[]) {
	return tagList.map((t) => `#${t}`).join(" ");
}
---

<MainGridLayout title={i18n(I18nKey.archive)}>
	{showCategoryBar && <CategoryBar />}
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<div class="card-base px-8 py-6" id="archive-panel">
		<!-- Filter indicator (hidden by default, shown by client script when filter params exist) -->
		<div id="archive-filter-indicator" class="mb-4 flex flex-wrap items-center gap-2 text-sm text-black/60 dark:text-white/60 hidden">
			<span>{i18n(I18nKey.filtering)}:</span>
			<div id="archive-filter-tags"></div>
			<div id="archive-filter-categories"></div>
			<span id="archive-filter-uncategorized" class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-[var(--primary)]/10 text-[var(--primary)] hidden">
				{i18n(I18nKey.uncategorized)}
			</span>
			<a
				href="/archive/"
				class="ml-2 text-black/40 dark:text-white/40 hover:text-[var(--primary)] transition-colors"
			>
				{i18n(I18nKey.clearFilter)}
			</a>
		</div>

		<!-- No results message (hidden by default) -->
		<div id="archive-no-results" class="text-center py-16 text-black/40 dark:text-white/40 hidden">
			{i18n(I18nKey.noData)}
		</div>

		<!-- All post groups, rendered server-side -->
		{groups.map((group, gi) => (
			<div class="archive-group" data-year={group.year}>
				<div class="flex flex-row w-full items-center h-[3.75rem]">
					<div class="w-[15%] md:w-[10%] transition text-2xl font-bold text-right text-75">
						{group.year}
					</div>
					<div class="w-[15%] md:w-[10%]">
						<div
							class="h-3 w-3 bg-none rounded-full outline outline-[var(--primary)] mx-auto
                  -outline-offset-[2px] z-50 outline-3"
						></div>
					</div>
					<div class="w-[70%] md:w-[80%] transition text-left text-50">
						<span class="archive-group-count">{group.posts.length}</span>
						{i18n(
							group.posts.length === 1
								? I18nKey.postCount
								: I18nKey.postsCount,
						)}
					</div>
				</div>

				{group.posts.map((post) => (
					<a
						href={post.url || `/posts/${post.id}/`}
						aria-label={post.data.title}
						class="group btn-plain !block h-10 w-full rounded-lg hover:text-[initial] archive-post-link"
						data-tags={post.data.tags?.join(",")}
						data-category={post.data.category || ""}
					>
						<div class="flex flex-row justify-start items-center h-full">
							<!-- date -->
							<div class="w-[15%] md:w-[10%] transition text-sm text-right text-50">
								{formatDate(post.data.published)}
							</div>

							<!-- dot and line -->
							<div class="w-[15%] md:w-[10%] relative dash-line h-full flex items-center">
								<div
									class="transition-all mx-auto w-1 h-1 rounded group-hover:h-5
                       bg-[oklch(0.5_0.05_var(--hue))] group-hover:bg-[var(--primary)]
                       outline outline-4 z-50
                       outline-[var(--card-bg)]
                       group-hover:outline-[var(--btn-plain-bg-hover)]
                       group-active:outline-[var(--btn-plain-bg-active)]"
								></div>
							</div>

							<!-- post title -->
							<div
								class="w-[70%] md:max-w-[65%] md:w-[65%] text-left font-bold
                     group-hover:translate-x-1 transition-all group-hover:text-[var(--primary)]
                     text-75 pr-8 whitespace-nowrap overflow-ellipsis overflow-hidden"
							>
								{post.data.title}
							</div>

							<!-- tag list -->
							<div
								class="hidden md:block md:w-[15%] text-left text-sm transition
                     whitespace-nowrap overflow-ellipsis overflow-hidden text-30"
							>
								{formatTag(post.data.tags)}
							</div>
						</div>
					</a>
				))}
			</div>
		))}
	</div>
</MainGridLayout>

<script>
	function applyArchiveFilter() {
		const params = new URLSearchParams(window.location.search);
		const filterTags = params.has("tag") ? params.getAll("tag") : [];
		const filterCategories = params.has("category") ? params.getAll("category") : [];
		const filterUncategorized = params.get("uncategorized");

		if (filterTags.length === 0 && filterCategories.length === 0 && !filterUncategorized) {
			return; // No filter, show all
		}

		const indicator = document.getElementById("archive-filter-indicator");
		const tagsContainer = document.getElementById("archive-filter-tags");
		const catsContainer = document.getElementById("archive-filter-categories");
		const uncategorizedEl = document.getElementById("archive-filter-uncategorized");
		const noResults = document.getElementById("archive-no-results");

		if (!indicator || !tagsContainer || !catsContainer || !uncategorizedEl || !noResults) {return;}

		// Show filter indicator
		indicator.classList.remove("hidden");

		// Render filter tag pills
		tagsContainer.innerHTML = "";
		for (const tag of filterTags) {
			const a = document.createElement("a");
			a.href = `/archive/?tag=${encodeURIComponent(tag)}`;
			a.className = "inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-[var(--primary)]/10 text-[var(--primary)] hover:bg-[var(--primary)]/20 transition-colors";
			a.textContent = `#${tag}`;
			tagsContainer.appendChild(a);
		}

		// Render filter category pills
		catsContainer.innerHTML = "";
		for (const cat of filterCategories) {
			const a = document.createElement("a");
			a.href = `/archive/?category=${encodeURIComponent(cat)}`;
			a.className = "inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-[var(--primary)]/10 text-[var(--primary)] hover:bg-[var(--primary)]/20 transition-colors";
			a.textContent = cat;
			catsContainer.appendChild(a);
		}

		// Show uncategorized pill
		if (filterUncategorized) {
			uncategorizedEl.classList.remove("hidden");
		}

		// Filter posts
		const postLinks = document.querySelectorAll<HTMLElement>(".archive-post-link");
		let visibleCount = 0;

		postLinks.forEach((el) => {
			const postTags = (el.dataset.tags || "").split(",").filter(Boolean);
			const postCategory = el.dataset.category || "";

			let visible = true;

			if (filterTags.length > 0) {
				visible = visible && postTags.some((t) => filterTags.includes(t));
			}

			if (filterCategories.length > 0) {
				visible = visible && filterCategories.includes(postCategory);
			}

			if (filterUncategorized) {
				visible = visible && !postCategory;
			}

			el.style.display = visible ? "" : "none";
			if (visible) {visibleCount++;}
		});

		// Update group counts and hide empty groups
		const groups = document.querySelectorAll<HTMLElement>(".archive-group");
		groups.forEach((group) => {
			const visiblePosts = group.querySelectorAll<HTMLElement>(".archive-post-link");
			let count = 0;
			visiblePosts.forEach((p) => {
				if (p.style.display !== "none") {count++;}
			});
			const countEl = group.querySelector(".archive-group-count");
			if (countEl) {countEl.textContent = String(count);}
			group.style.display = count === 0 ? "none" : "";
		});

		// Show no results if needed
		if (visibleCount === 0) {
			noResults.classList.remove("hidden");
		}
	}

	// Apply on initial load
	applyArchiveFilter();

	// Re-apply after Swup page transitions
	document.addEventListener("swup:content-replace", applyArchiveFilter);
</script>