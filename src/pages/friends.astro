---
import Comment from "@components/comment/index.astro";
import FriendsCircle from "@components/features/friends/FriendsCircle.astro";
import { PageHeader } from "@components/features/page-header";
import Markdown from "@components/misc/Markdown.astro";
import { getEntry, render } from "astro:content";
import { Icon } from "astro-icon/components";

import { commentConfig, friendsConfig, profileConfig, siteConfig } from "@/config";
import { getFriendsListByConfig } from "@/data/friends";
import { getFriendsCircleLastUpdated, getFriendsCircleList } from "@/data/friends-circle";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

export const prerender = true;

if (!siteConfig.featurePages.friends) {
  return Astro.redirect("/404/");
}

const friendsPost = await getEntry("spec", "friends");
const { Content } = friendsPost ? await render(friendsPost) : { Content: () => {} };

const isCommentEnabled = commentConfig?.enable && friendsConfig.showComment !== false;
const title = friendsConfig.title || i18n(I18nKey.friendsTitle);
const description = friendsConfig.description || i18n(I18nKey.friendsDescription);
const randomize = friendsConfig.randomizeSort ?? true;
const friendsList = getFriendsListByConfig(randomize);
const friendsCircleList = friendsConfig.showFriendsCircle !== false ? getFriendsCircleList() : [];
const friendsCircleLastUpdated = friendsConfig.showFriendsCircle !== false ? getFriendsCircleLastUpdated() : "";

// 收集所有标签
const allTags = [...new Set(friendsList.flatMap((f) => f.tags || []))];

// 本站信息
const mySiteInfo = {
  name: siteConfig.title || "Mizuki Blog",
  url: siteConfig.siteURL || "https://mizuki.mysqil.com/",
  avatar: (profileConfig.avatar || "/favicon.png").startsWith("/") ? (profileConfig.avatar || "/favicon.png") : `/${profileConfig.avatar || "favicon.png"}`,
  desc: profileConfig.bio || "一个使用 Mizuki 主题的 Astro 博客",
};

// 注意事项
const notes = [
  { title: "互换原则", content: "请先将本站添加到您的友链页面，确认后会添加您的友链" },
  { title: "链接维护", content: "友链网站长期无法访问或内容违规，将会被移除" },
  { title: "内容要求", content: "内容积极向上，不含有任何违法违规内容" },
  { title: "站点要求", content: "支持 HTTPS，以原创内容为主，能够正常访问且有持续更新" },
  { title: "RSS 订阅", content: "提供 RSS 地址可让你的最新文章出现在朋友圈中" },
];

// 站点信息字段（可复制）
const siteInfoFields = [
  { label: "站点名称", value: mySiteInfo.name },
  { label: "站点描述", value: mySiteInfo.desc },
  { label: "站点链接", value: mySiteInfo.url },
  { label: "头像链接", value: mySiteInfo.avatar },
];
---

<MainGridLayout title={title} description={description}>
  <!-- 1. 友链卡片（全宽） -->
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
      <PageHeader title="友情链接" subtitle="这里是我的朋友们，欢迎互相访问交流" icon="material-symbols:group" />

      <!-- 标签筛选 -->
      {allTags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-6">
          <button
            class="friend-tag active px-3 py-1.5 rounded-lg bg-[var(--primary)] text-white hover:bg-[var(--primary)] transition-colors duration-200 text-sm font-medium cursor-pointer"
            data-tag="all"
          >
            {i18n(I18nKey.tagAll) || "全部"}
          </button>
          {allTags.map((tag) => (
            <button
              class="friend-tag px-3 py-1.5 rounded-lg bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors duration-200 text-sm font-medium cursor-pointer"
              data-tag={tag}
            >
              {tag}
            </button>
          ))}
        </div>
      )}

      <!-- 友链列表 -->
      <div class="friends-grid">
        {friendsList.map((friend) => (
          <a
            href={friend.siteurl}
            target="_blank"
            rel="noopener noreferrer"
            class="friend-card group flex items-center gap-3 p-2.5 rounded-xl border border-[var(--line-divider)] hover:border-[var(--primary)] transition-all duration-300 hover:shadow-lg relative overflow-hidden"
            data-tags={friend.tags?.join(",") || ""}
          >
            {/* 背景装饰 */}
            <div class="absolute inset-0 bg-[var(--primary)] opacity-0 group-hover:opacity-5 transition-opacity duration-300 pointer-events-none" />

            {/* 头像 */}
            <div class="relative w-16 h-16 shrink-0 rounded-xl overflow-hidden bg-zinc-100 dark:bg-zinc-800 border border-black/5 dark:border-white/5 group-hover:scale-105 transition-transform duration-300">
              <img
                src={friend.imgurl}
                alt={friend.title}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>

            {/* 内容 */}
            <div class="grow min-w-0 flex flex-col justify-center gap-0.5">
              <div class="flex items-center justify-between">
                <div class="font-bold text-base text-neutral-900 dark:text-neutral-100 group-hover:text-[var(--primary)] transition-colors truncate pr-4">
                  {friend.title}
                </div>
                <Icon
                  name="material-symbols:arrow-outward-rounded"
                  class="text-[var(--primary)] text-lg opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300"
                />
              </div>

              <div class="text-sm text-neutral-500 dark:text-neutral-400 line-clamp-1" title={friend.desc}>
                {friend.desc}
              </div>

              {/* 标签 */}
              {friend.tags && friend.tags.length > 0 && (
                <div class="flex flex-wrap gap-1 mt-1">
                  {friend.tags.slice(0, 3).map((tag) => (
                    <span class="text-[0.65rem] px-1.5 py-0.5 rounded bg-neutral-100 dark:bg-neutral-800 text-neutral-500 dark:text-neutral-400">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- 2. 朋友圈 -->
  {friendsCircleList.length > 0 && (
    <div class="mt-4 flex w-full rounded-[var(--radius-large)] overflow-hidden relative">
      <div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
        <FriendsCircle items={friendsCircleList} lastUpdated={friendsCircleLastUpdated || undefined} />
      </div>
    </div>
  )}

  <!-- 3. 自定义内容（本站信息 + 申请流程 双栏 + 注意事项） -->
  {friendsPost && friendsConfig.showCustomContent !== false && (
    <div class="mt-4 card-base z-10 px-6 md:px-9 py-6 relative w-full">
      <Markdown class=""><Content /></Markdown>
    </div>
  )}

  <!-- 4. 评论区 -->
  {isCommentEnabled && (
    <div class="mt-4">
      <Comment path="/friends/" />
    </div>
  )}
</MainGridLayout>

<style is:global>
  .friends-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }

  .friend-tag.active {
    background-color: var(--primary);
    color: white;
  }
</style>

<script>
  // @ts-nocheck
  document.addEventListener("DOMContentLoaded", () => {
    const tags = document.querySelectorAll(".friend-tag");
    const cards = document.querySelectorAll(".friend-card");

    tags.forEach((tag) => {
      tag.addEventListener("click", () => {
        tags.forEach((t) => {
          t.classList.remove("active");
          t.classList.remove("bg-[var(--primary)]", "text-white");
          t.classList.add("bg-neutral-100", "dark:bg-neutral-800", "text-neutral-600", "dark:text-neutral-400");
        });
        tag.classList.add("active");
        tag.classList.add("bg-[var(--primary)]", "text-white");
        tag.classList.remove("bg-neutral-100", "dark:bg-neutral-800", "text-neutral-600", "dark:text-neutral-400");

        const selectedTag = tag.getAttribute("data-tag");

        cards.forEach((card) => {
          if (selectedTag === "all") {
            card.style.display = "";
          } else {
            const cardTags = card.getAttribute("data-tags") || "";
            card.style.display = cardTags.includes(selectedTag) ? "" : "none";
          }
        });
      });
    });

    // 点击复制
    const copyBtns = document.querySelectorAll(".friend-copy-btn");
    copyBtns.forEach((btn) => {
      btn.addEventListener("click", async () => {
        const text = btn.getAttribute("data-copy");
        if (text) {
          try {
            await navigator.clipboard.writeText(text);
            btn.innerHTML = '<iconify-icon icon="material-symbols:check" class="text-sm text-green-500"></iconify-icon>';
            setTimeout(() => {
              btn.innerHTML = '<iconify-icon icon="material-symbols:content-copy-outline" class="text-sm"></iconify-icon>';
            }, 1500);
          } catch {
            const textarea = document.createElement("textarea");
            textarea.value = text;
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand("copy");
            document.body.removeChild(textarea);
          }
        }
      });
    });
  });
</script>