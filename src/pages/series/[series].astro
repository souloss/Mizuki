---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { formatDateToYYYYMMDD } from "@utils/date-utils";
import { getSeriesData } from "@utils/series-utils";
import { getPostUrl } from "@utils/url-utils";
import { Icon } from "astro-icon/components";

export async function getStaticPaths() {
	const { getAllSeries } = await import("@utils/series-utils");
	const allSeries = await getAllSeries();
	return allSeries.map((series) => ({
		params: { series: series.name },
		props: { seriesName: series.name },
	}));
}

const { seriesName } = Astro.props;
const seriesInfo = await getSeriesData(seriesName);

if (!seriesInfo) {
	return Astro.redirect("/series/");
}
---

<MainGridLayout
	title={seriesInfo.name}
	description={i18n(I18nKey.seriesDesc).replace("{name}", seriesInfo.name)}
>
	<div class="card-base px-6 md:px-9 pt-6 pb-4 rounded-[var(--radius-large)] mb-4">
		<div class="flex items-center gap-2 mb-2 onload-animation">
			<Icon name="material-symbols:list-alt-rounded" class="text-2xl text-[var(--primary)]" />
			<h1 class="text-2xl font-bold transition text-black/90 dark:text-white/90">
				{seriesInfo.name}
			</h1>
		</div>
		<div class="text-sm transition text-black/50 dark:text-white/50 mb-6 onload-animation">
			{seriesInfo.posts.length} {i18n(I18nKey.seriesTotalPosts)}
		</div>

		<ol class="space-y-3">
			{seriesInfo.posts.map((post, index) => {
				const href = getPostUrl({ id: post.id, filePath: post.filePath, data: { permalink: post.permalink, slug: post.slug } } as any)
				const num = String(index + 1).padStart(2, "0")

				return (
					<li class="onload-animation" style={`--i: ${index}; --interval: 50ms;`}>
						<a
							href={href}
							class="group flex items-start gap-4 p-4 rounded-xl border border-black/5 dark:border-white/10 hover:border-[var(--primary)] transition-all duration-300"
						>
							<span class="font-mono text-lg font-bold text-[var(--primary)] opacity-50 group-hover:opacity-100 transition-opacity">
								{num}
							</span>
							<div class="flex-1 min-w-0">
								<h2 class="text-base font-bold transition text-black/75 dark:text-white/75 group-hover:text-[var(--primary)] truncate">
									{post.title}
								</h2>
								<time class="text-xs transition text-black/30 dark:text-white/30">
									{formatDateToYYYYMMDD(post.published)}
								</time>
							</div>
							<Icon
								name="material-symbols:arrow-forward-rounded"
								class="text-lg transition text-black/20 dark:text-white/20 group-hover:text-[var(--primary)] mt-1"
							/>
						</a>
					</li>
				)
			})}
		</ol>
	</div>
</MainGridLayout>