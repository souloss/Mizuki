diff --git a/src/internal/client/dom/operations.js b/src/internal/client/dom/operations.js
index 4036aa2d61bb5346b330e8e60b58aa38d22271b1..c24e97099fda093a62af596524ef319ded0ec758 100644
--- a/src/internal/client/dom/operations.js
+++ b/src/internal/client/dom/operations.js
@@ -291,3 +291,13 @@ export function merge_text_nodes(text) {
 		next = text.nextSibling;
 	}
 }
+
+// Eagerly initialize DOM operations when this module loads in the browser.
+// Without this, Vite's dev-mode async module loading can cause Svelte components
+// to call get_first_child/get_next_sibling before init_operations() has run,
+// resulting in "Cannot read properties of undefined (reading 'call')" errors.
+// In production (Rollup), modules are bundled synchronously so this is a no-op
+// (init_operations returns immediately if already initialized).
+if (typeof window !== 'undefined') {
+	init_operations();
+}
